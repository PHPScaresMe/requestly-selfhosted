# Copy to server/.env (gitignored) and fill in. The functions container reads these
# at startup via docker-compose env_file. The SPA never sees them.

# SMTP relay for transactional email (password reset, shared-list invites, session
# recording shares). Required for these flows to actually deliver; otherwise the
# emulator's auth emails are captured to the Emulator UI at http://localhost:4000.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=notify@example.com
SMTP_PASSWORD=changeme
SMTP_FROM_NAME="Self-hosted Requestly"
SMTP_FROM_EMAIL=notify@example.com

# Public-facing URL of this self-hosted instance. Pasted into outbound emails so
# links resolve to your deployment, not the SaaS hosts. No trailing slash.
PUBLIC_APP_URL=http://localhost:3005
