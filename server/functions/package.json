{
  "name": "requestly-functions",
  "version": "0.1.0",
  "description": "Open-source reimplementation of requestly-backend cloud functions, for self-hosting.",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "tsc --noEmit",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@requestly/mock-server": "^0.3.3",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "nanoid": "^3.3.7",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.4.0"
  }
}
